    {
      "parameters": {
        "jsCode": "const body = $('Webhook: Lead Intake').first().json.body;\nconst naam = body.naam || '';\nconst bedrijf = body.bedrijf || 'Niet opgegeven';\nconst bericht = body.bericht || 'Geen bericht';\nconst bron = body.bron || 'Onbekend';\n\nconst prompt = 'Analyseer deze lead en geef een JSON terug met deze exacte velden:\\n{\\n  \"score\": \"hoog\" of \"middel\" of \"laag\",\\n  \"sector\": \"string (bijv. IT, Bouw, Marketing, Consultancy, Bouw, SaaS, E-commerce, Zorg, etc.)\",\\n  \"samenvatting\": \"1 zin over de lead\",\\n  \"prioriteit\": getal van 1 tot 10\\n}\\n\\nScoreregels:\\n- hoog: heeft bedrijfsnaam, concreet verzoek, meerdere diensten of hoge urgentie (prioriteit 8-10)\\n- middel: serieuze interesse maar minder specifiek (prioriteit 5-7)\\n- laag: oriënterend, geen bedrijf, vaag bericht (prioriteit 1-4)\\n\\nLead data:\\nNaam: ' + naam + '\\nBedrijf: ' + bedrijf + '\\nBericht: ' + bericht + '\\nGevraagde diensten: ' + bron + '\\n\\nGeef ALLEEN de JSON terug, geen uitleg.';\n\nreturn [{ json: { naam, bedrijf, bericht, bron, prompt } }];"
      },
      "id": "node-prep-score",
      "name": "Code: Bereid Score Data Voor",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.ANTHROPIC_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-haiku-4-5-20251001', max_tokens: 300, messages: [{ role: 'user', content: $json.prompt }] }) }}",
        "options": {}
      },
      "id": "node-claude-score",
      "name": "Claude AI: Score Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        840,
        300
