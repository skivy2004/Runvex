    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nlet ai = { score: 'middel', sector: 'Onbekend', samenvatting: 'Geen samenvatting beschikbaar', prioriteit: 5 };\ntry {\n  const text = response.content[0].text;\n  const cleaned = text.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n  ai = JSON.parse(cleaned);\n} catch(e) {}\nreturn [{ json: { ai_score: ai.score || 'middel', ai_sector: ai.sector || 'Onbekend', ai_samenvatting: ai.samenvatting || '', ai_prioriteit: parseInt(ai.prioriteit) || 5 } }];"
      },
