# =============================================================
#  Lead Automatisering — Environment Variabelen
#  Kopieer dit bestand naar .env en vul de waarden in.
#  Commit NOOIT je echte .env naar git!
# =============================================================

# --- Supabase ---------------------------------------------------
# Te vinden in: Supabase dashboard → Project Settings → API

# De URL van jouw Supabase project
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Publieke "anon" sleutel (veilig voor server-side n8n gebruik)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role sleutel — ALLEEN gebruiken als anon key niet werkt door RLS
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Resend -----------------------------------------------------
# Te vinden in: resend.com → API Keys

# Jouw Resend API sleutel
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- E-mailadressen --------------------------------------------

# Het "from" adres dat Resend gebruikt (moet geverifieerd domein zijn)
BEDRIJF_EMAIL=noreply@jouwbedrijf.nl

# Het adres van de eigenaar die notificaties ontvangt
EIGENAAR_EMAIL=jij@jouwbedrijf.nl

# --- n8n -------------------------------------------------------
# Alleen nodig als je het formulier en n8n op verschillende servers draait

# De publieke webhook URL uit n8n (Webhook node → "Production URL")
N8N_WEBHOOK_URL=http://localhost:5678/webhook/lead-intake

# --- Google Calendar (Booking) ---------------------------------
# Te vinden in: Google Cloud Console → APIs & Services → Credentials

GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_ID=primary

# E-mail van de eigenaar die boekingsnotificaties ontvangt (voor booking API)
MY_EMAIL=jij@jouwbedrijf.nl

# --- Apify (LinkedIn Scraper) ----------------------------------
# Te vinden in: apify.com → Settings → Integrations → API tokens
# Account aanmaken op: https://apify.com/sign-up

APIFY_API_KEY=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Dashboard secrets -----------------------------------------
# Willekeurige strings om dashboard API endpoints te beveiligen
# Beide moeten EXACT dezelfde waarde hebben

DASHBOARD_SECRET=jouw-dashboard-sleutel
NEXT_PUBLIC_DASHBOARD_SECRET=jouw-dashboard-sleutel

# --- Weekrapport secret ----------------------------------------
# Willekeurige string om de /api/weekly-report endpoint te beveiligen

REPORT_SECRET=jouw-geheime-sleutel
